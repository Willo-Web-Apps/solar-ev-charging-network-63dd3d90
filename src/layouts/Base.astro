---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { title = "Solva — Red de Carga Solar para VE en Colombia", description = "Solva instala cargadores rápidos con energía solar en parqueaderos y edificios comerciales en Bogotá y Medellín. Encuentra, reserva y carga en minutos desde la app." } = Astro.props;
---
<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <title>{title}</title>
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Solva",
      "description": "Red de carga solar para vehículos eléctricos en Colombia. Cargadores rápidos en parqueaderos y edificios comerciales en Bogotá y Medellín.",
      "url": "https://solar-ev-charging-network.onrender.com"
    }
    </script>
  </head>
  <body class="min-h-screen flex flex-col bg-surface-50 text-surface-900 font-body antialiased">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
